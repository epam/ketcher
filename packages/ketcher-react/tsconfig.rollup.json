{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "target": "esnext"
  },
  "include": ["rollup.config.ts", "rollup-plugin-shims.d.ts"]
}
