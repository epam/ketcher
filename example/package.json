{
  "name": "ketcher-react-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:standalone": "cross-env MODE=standalone vite",
    "dev:remote": "cross-env MODE=remote vite",
    "start:standalone": "cross-env MODE=standalone react-app-rewired start",
    "start:remote": "cross-env MODE=remote react-app-rewired start",
    "init:build": "shx mkdir -p build",
    "init:dist:standalone": "shx mkdir -p dist/standalone",
    "init:dist:remote": "shx mkdir -p dist/remote",
    "delete:dist:standalone": "shx rm -rf dist/standalone",
    "delete:dist:remote": "shx rm -rf dist/remote",
    "copy:build:standalone": "shx cp -r build/. dist/standalone",
    "copy:build:remote": "shx cp -r build/. dist/remote",
    "prepare:dist:standalone": "run-s init:build delete:dist:standalone init:dist:standalone",
    "prepare:dist:remote": "run-s init:build delete:dist:remote init:dist:remote",
    "finalize:dist:standalone": "npm run copy:build:standalone",
    "finalize:dist:remote": "npm run copy:build:remote",
    "build:react:standalone": "cross-env MODE=standalone NODE_OPTIONS=--require=./scripts/react-dev-utils-node24-preload.cjs react-app-rewired build && echo standalone",
    "build:react:remote": "cross-env MODE=remote NODE_OPTIONS=--require=./scripts/react-dev-utils-node24-preload.cjs react-app-rewired build && echo remote",
    "build:remote": "run-s prepare:dist:remote build:react:remote finalize:dist:remote",
    "build:standalone": "run-s prepare:dist:standalone build:react:standalone finalize:dist:standalone",
    "build:react:analyze": "cross-env NODE_OPTIONS=--require=./scripts/react-dev-utils-node24-preload.cjs react-app-rewired build --analyze",
    "build": "npm run build:standalone && npm run build:remote",
    "build:standalone:analyze": "cross-env MODE=standalone run-s prepare:dist:standalone build:react:analyze finalize:dist:standalone",
    "build:remote:analyze": "cross-env MODE=remote run-s prepare:dist:remote build:react:analyze finalize:dist:remote",
    "test": "run-s test:prettier test:stylelint test:eslint:quiet test:types test:unit",
    "test:eslint": "eslint . --ext .ts,.js,.jsx,.tsx",
    "test:eslint:quiet": "npm run test:eslint -- --quiet",
    "test:eslint:fix": "npm run test:eslint -- --fix",
    "test:types": "tsc --noEmit",
    "test:unit": "react-app-rewired test --passWithNoTests --watchAll=false",
    "test:stylelint": "stylelint \"./**/*.{css,less}\" --formatter",
    "test:prettier": "prettier --check \"./**/*.{js,ts,jsx,tsx,json}\"",
    "prettier:write": "prettier --write \"./**/*.{js,jsx,json,ts,tsx}\"",
    "stylelint:fix": "stylelint \"./**/*.{css,less}\" --formatter verbose --fix",
    "serve:remote": "serve dist/remote -c serve.json -l tcp://127.0.0.1:4001",
    "serve:standalone": "serve dist/standalone -c serve.json -l tcp://127.0.0.1:4002",
    "eject": "react-scripts eject"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^5.18.0",
    "ketcher-core": "*",
    "ketcher-macromolecules": "*",
    "ketcher-react": "*",
    "ketcher-standalone": "*",
    "normalize.css": "^8.0.1",
    "react": "^19.1.0",
    "react-app-polyfill": "^2.0.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@rollup/plugin-replace": "^5.0.2",
    "@testing-library/jest-dom": "^4.2.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^7.2.1",
    "@types/jest": "^27.0.3",
    "@types/node": "^22.12.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "@welldone-software/why-did-you-render": "^4.3.1",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^7.0.3",
    "customize-cra": "^1.0.0",
    "eslint": "^8.44.0",
    "git-revision-webpack-plugin": "^3.0.6",
    "html-replace-webpack-plugin": "^2.5.6",
    "less": "^4.2.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.5.1",
    "react-app-rewired": "^2.2.1",
    "react-scripts": "^5.0.1",
    "serve": "^14.2.6",
    "shx": "^0.3.3",
    "source-map-loader": "^3.0.1",
    "typescript": "^6.0.3",
    "vite": "8.0.16",
    "vite-plugin-commonjs": "^0.10.4",
    "vite-plugin-html": "^3.2.0",
    "vite-plugin-raw": "^1.0.3",
    "vite-plugin-svgr": "^4.5.0",
    "webpack-bundle-analyzer": "^4.8.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "ie 11",
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config-overrides-path": "config/webpack.config.js"
}
