{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "paths": {
      "components": ["./src/components"],
      "src/*": ["./src/*"],
      "ketcher-core": ["../ketcher-core/src"],
      "domain/*": ["../ketcher-core/src/domain/*"],
      "infrastructure/*": ["../ketcher-core/src/infrastructure/*"],
      "application/*": ["../ketcher-core/src/application/*"],
      "utilities": ["../ketcher-core/src/utilities"],
      "types": ["../ketcher-core/src/types"]
    },
    "moduleResolution": "bundler",
    "rootDir": "../.."
  },
  "include": ["src", "rollup-plugin-shims.d.ts"]
}
