{
  "name": "ketcher-core",
  "version": "3.17.0-rc.2",
  "description": "Web-based molecule sketcher",
  "license": "Apache-2.0",
  "homepage": "http://lifescience.opensource.epam.com/ketcher",
  "author": {
    "name": "EPAM Life Sciences",
    "url": "http://lifescience.opensource.epam.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/epam/ketcher.git",
    "directory": "packages/ketcher-core"
  },
  "keywords": [
    "molecule",
    "sketcher",
    "chemistry"
  ],
  "bugs": {
    "url": "https://github.com/epam/ketcher/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.modern.js",
  "source": "src/index.ts",
  "engines": {
    "node": ">=24.14.1"
  },
  "scripts": {
    "ajv": "node ./scripts/compile-ket-schema.cjs",
    "prebuild": "npm run ajv && shx rm -rf dist",
    "build": "cross-env NODE_ENV=production rollup -c -m true && tsc-alias -p tsconfig.json",
    "prestart": "npm run ajv",
    "start": "cross-env NODE_ENV=development rollup -c -m true -w",
    "test": "run-s test:prettier test:eslint:quiet test:types test:circ test:unit",
    "test:circ": "dpdm --no-warning --no-tree -T --exit-code circular:1 ./src/index.ts",
    "test:eslint": "eslint . --ext .ts,.js",
    "test:eslint:quiet": "npm run test:eslint -- --quiet",
    "test:eslint:fix": "npm run test:eslint -- --fix",
    "test:types": "tsc --noEmit",
    "test:unit": "jest",
    "test:unit:update": "jest -u",
    "test:prettier": "prettier --check \"./**/*.{js,ts,json}\"",
    "prettier:write": "prettier --write \"./**/*.{js,ts,json}\"",
    "typedoc": "typedoc"
  },
  "dependencies": {
    "@babel/runtime": "^7.26.10",
    "ajv": "^8.10.0",
    "assert": "^2.0.0",
    "d3": "^7.8.5",
    "dpdm": "^4.2.0",
    "file-saver": "^2.0.5",
    "jsonschema": "^1.5.0",
    "lodash": "^4.18.1",
    "paper": "^0.12.18",
    "raphael": "^2.3.0",
    "react-device-detect": "^2.2.2",
    "svgpath": "^2.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.6",
    "@babel/plugin-transform-runtime": "^7.17.0",
    "@babel/preset-env": "^7.16.11",
    "@babel/preset-typescript": "^7.16.7",
    "@rollup/plugin-babel": "^5.2.1",
    "@rollup/plugin-commonjs": "^16.0.0",
    "@rollup/plugin-json": "^4.1.0",
    "@rollup/plugin-node-resolve": "^10.0.0",
    "@rollup/plugin-replace": "^2.3.4",
    "@rollup/plugin-strip": "^2.0.0",
    "@rollup/plugin-typescript": "^11.1.4",
    "@types/d3": "^7.4.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "ajv": "^8.18.0",
    "babel-jest": "^30.3.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.44.0",
    "eslint-plugin-jest": "^25.3.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.4.1",
    "jest-mock-extended": "^2.0.4",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.5.1",
    "rollup": "^2.80.0",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-copy": "^3.4.0",
    "rollup-plugin-delete": "^2.0.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-string": "^3.0.0",
    "rollup-plugin-visualizer": "^5.5.2",
    "ts-jest": "^29.4.11",
    "tsc-alias": "^1.8.17",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist"
  ]
}
