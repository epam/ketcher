{
  "name": "ketcher-react-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:standalone": "cross-env MODE=standalone vite",
    "dev:remote": "cross-env MODE=remote vite",
    "start:standalone": "npm run dev:standalone",
    "start:remote": "npm run dev:remote",
    "build:remote": "cross-env MODE=remote vite build --mode production --outDir dist/remote && shx cp serve.json dist/remote/serve.json",
    "build:standalone": "cross-env MODE=standalone vite build --mode production --outDir dist/standalone && shx cp serve.json dist/standalone/serve.json",
    "build": "run-s build:standalone build:remote",
    "build:standalone:analyze": "cross-env ANALYZE=true npm run build:standalone",
    "build:remote:analyze": "cross-env ANALYZE=true npm run build:remote",
    "test": "run-s test:prettier test:stylelint test:eslint:quiet test:types test:unit",
    "test:eslint": "eslint . --ext .ts,.js,.jsx,.tsx",
    "test:eslint:quiet": "npm run test:eslint -- --quiet",
    "test:eslint:fix": "npm run test:eslint -- --fix",
    "test:types": "tsc --noEmit",
    "test:unit": "vitest run --passWithNoTests",
    "test:stylelint": "stylelint \"./**/*.{css,less}\" --formatter",
    "test:prettier": "prettier --check \"./**/*.{js,ts,jsx,tsx,json}\"",
    "prettier:write": "prettier --write \"./**/*.{js,jsx,json,ts,tsx}\"",
    "stylelint:fix": "stylelint \"./**/*.{css,less}\" --formatter verbose --fix",
    "serve:remote": "serve dist/remote -c serve.json -l tcp://127.0.0.1:4001",
    "serve:standalone": "serve dist/standalone -c serve.json -l tcp://127.0.0.1:4002"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^5.18.0",
    "ketcher-core": "*",
    "ketcher-macromolecules": "*",
    "ketcher-react": "*",
    "ketcher-standalone": "*",
    "normalize.css": "^8.0.1",
    "react": "^19.1.0",
    "react-app-polyfill": "^2.0.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@rollup/plugin-replace": "^5.0.2",
    "@testing-library/jest-dom": "^4.2.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^7.2.1",
    "@types/node": "^22.12.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "@welldone-software/why-did-you-render": "^4.3.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.44.0",
    "jsdom": "^29.0.1",
    "less": "^4.4.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.5.1",
    "serve": "^14.2.6",
    "shx": "^0.3.3",
    "typescript": "^4.5.2",
    "vite": "^8.0.3",
    "vite-plugin-commonjs": "^0.10.4",
    "vite-plugin-raw": "^1.0.3",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.1.2"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "ie 11",
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
